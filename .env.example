# Copy to .env and fill in real values before running the demo.
# .env is gitignored — never commit real credentials.

# ── Docker Compose ────────────────────────────────────────────────────────────
AUTH_DB_PASSWORD=postgres          # postgres-auth container password
GATEWAY_DB_PASSWORD=postgres       # postgres-gateway container password
RSA_KEY_ID=key-2024-01             # kid for the active RSA key pair
TOKEN_EXPIRE_MINUTES=60
GITHUB_TOKEN=ghp_...               # GitHub PAT with repo read scope — needed to pull AgentCore

# ── SREDemo Web UI ────────────────────────────────────────────────────────────
USE_SYNTHETIC_DATA=true            # true = pre-canned VPN data; false = real AWS/Datadog/PagerDuty calls
USE_MOCK_LLM=true                  # true = pre-scripted events, no ANTHROPIC_API_KEY needed
SERVER_PORT=3000                   # port the FastAPI/React UI is served on
DEMO_CONTEXT_LIMIT=15000           # token ceiling for budget gauge display
DEMO_COMPACT_THRESHOLD=0.80        # fraction that triggers animated compaction

# ── Auth Service URL (set automatically in compose; override for local runs) ──
AUTH_SERVICE_URL=http://localhost:9000

# Anthropic (LLM backbone) — required even in synthetic mode
ANTHROPIC_API_KEY=sk-ant-...

# ── Real-stack credentials (only needed when USE_SYNTHETIC_DATA=false) ────────

# AWS (VPN API calls via boto3)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# Datadog (metrics query)
DD_API_KEY=...
DD_APP_KEY=...
DD_SITE=datadoghq.com

# PagerDuty
PD_API_KEY=...            # REST API token — Bearer auth
PD_ROUTING_KEY=...        # Events API v2 integration key
PD_FROM_EMAIL=sre@example.com
PD_SERVICE_ID=PXXXXXX     # PagerDuty service ID for incident routing
